{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentShield",
  "version": "0.1.0",
  "identifier": "dev.agentshield.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AgentShield 监控面板",
        "width": 1280,
        "height": 820,
        "url": "http://127.0.0.1:8787"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
